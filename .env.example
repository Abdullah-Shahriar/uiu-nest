# ============================================================
#  UIU Nest — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  DO NOT put real secrets in this file!
# ============================================================

# ----- Application -----
APP_NAME="UIU Nest"
APP_URL="http://localhost/GitHub/uiu-nest"
APP_ENV="local"
# APP_ENV options: local | staging | production

# ----- Database -----
DB_HOST="localhost"
DB_NAME="uiu_nest"
DB_USER="root"
DB_PASS=""
DB_CHARSET="utf8mb4"

# ----- University Coordinates (UIU Main Campus) -----
UIU_LAT="23.798038"
UIU_LNG="90.449842"

# ----- File Upload Limits -----
MAX_IMAGE_SIZE_MB="5"
MAX_VIDEO_SIZE_MB="30"

# ----- Groq AI API -----
GROQ_API_KEY="your_groq_api_key_here"
GROQ_API_URL="https://api.groq.com/openai/v1/chat/completions"
GROQ_MODEL="llama-3.3-70b-versatile"
